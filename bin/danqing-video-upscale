#!/usr/bin/env python3
"""
danqing-video-upscale — 视频修复 CLI。

对应 REST API: POST /api/videos/upscales → IVideoEngine.upscale()

用法:
    danqing-video-upscale --model seedvr2-video-7b:fp16 --source-asset-id ast_xxx \
                          --scale 4 --output out.mp4
"""
from __future__ import annotations

import argparse
import os
import sys
from pathlib import Path

_CLI_FILE = Path(__file__).resolve()
PROJECT_ROOT = _CLI_FILE.parent.parent
if sys.platform != "win32":
    _venv_root = PROJECT_ROOT / ".venv"
    _venv_py = _venv_root / "bin" / "python3"
    if _venv_py.is_file() and Path(sys.prefix).resolve() != _venv_root.resolve():
        os.execv(str(_venv_py), [str(_venv_py), str(_CLI_FILE), *sys.argv[1:]])
sys.path.insert(0, str(PROJECT_ROOT))

from backend.cli.video_cli import upscale


def main():
    parser = argparse.ArgumentParser(description="DanQing CLI: video restoration (SeedVR2 spatiotemporal SR)")
    parser.add_argument("--model", required=True)
    parser.add_argument("--source-asset-id", required=True)
    parser.add_argument("--scale", type=int, default=2, choices=(2, 4))
    parser.add_argument("--denoise", type=float, default=0.3)
    parser.add_argument("--max-frames", type=int, default=600)
    parser.add_argument("--seed", type=int, default=None)
    parser.add_argument("--output", required=True)
    parser.add_argument("--project-root", default=str(PROJECT_ROOT))
    args = parser.parse_args()

    print(
        f"[cli] model={args.model} source_asset_id={args.source_asset_id!r} "
        f"scale={args.scale} max_frames={args.max_frames}"
    )
    upscale(
        model=args.model,
        source_asset_id=args.source_asset_id,
        scale=args.scale,
        denoise=args.denoise,
        max_frames=args.max_frames,
        seed=args.seed,
        output=args.output,
        project_root=Path(args.project_root).resolve(),
    )


if __name__ == "__main__":
    main()
