#!/usr/bin/env python3
"""
danqing-generate — 文生图 CLI。

对应 REST API: POST /api/images/generations → IImageEngine.generate()

用法:
    danqing-generate --model z-image --prompt "a mountain" --seed 42 --steps 4 --output out.png

    # FLUX.1 structural guide (Canny / Depth / Redux)
    danqing-generate --model flux1-dev --prompt "a castle" \
        --controlnet flux-canny-controlnet --control-image ref.png \
        --controlnet-strength 0.8 --guidance 30 --output out.png
"""
from __future__ import annotations

import argparse
import os
import sys
from pathlib import Path

_CLI_FILE = Path(__file__).resolve()
PROJECT_ROOT = _CLI_FILE.parent.parent
# Prefer repo venv (MLX) when the user runs ./bin/danqing-* without activating .venv
if sys.platform != "win32":
    _venv_root = PROJECT_ROOT / ".venv"
    _venv_py = _venv_root / "bin" / "python3"
    if _venv_py.is_file() and Path(sys.prefix).resolve() != _venv_root.resolve():
        os.execv(str(_venv_py), [str(_venv_py), str(_CLI_FILE), *sys.argv[1:]])
sys.path.insert(0, str(PROJECT_ROOT))

from backend.cli.image_cli import generate


def main():
    parser = argparse.ArgumentParser(description="DanQing CLI: text-to-image generation")
    parser.add_argument("--model", required=True, help="Model ID (e.g. z-image, z-image-turbo)")
    parser.add_argument("--prompt", required=True)
    parser.add_argument("--negative-prompt", default="")
    parser.add_argument("--size", default="1024x1024")
    parser.add_argument("--steps", type=int, default=None)
    parser.add_argument("--guidance", type=float, default=None)
    parser.add_argument("--seed", type=int, default=None)
    parser.add_argument(
        "--scheduler",
        default=None,
        help="Override scheduler id (registry default if omitted; e.g. linear, flow_match_euler_discrete)",
    )
    parser.add_argument(
        "--controlnet",
        default="",
        help="Registry controlnet id for structural_guide (e.g. flux-canny-controlnet; flux1 base only)",
    )
    parser.add_argument("--control-asset-id", default="", help="Gallery asset id for structural guide image")
    parser.add_argument(
        "--control-image",
        default="",
        help="Local guide image path (uploaded as asset; use with --controlnet)",
    )
    parser.add_argument(
        "--controlnet-strength",
        type=float,
        default=0.8,
        help="Structural guide weight (default 0.8)",
    )
    parser.add_argument("--output", required=True, help="Output image path")
    parser.add_argument("--project-root", default=str(PROJECT_ROOT))
    args = parser.parse_args()

    print(f"[cli] model={args.model} prompt={args.prompt!r} seed={args.seed} steps={args.steps}")
    generate(
        model=args.model,
        prompt=args.prompt,
        negative_prompt=args.negative_prompt,
        size=args.size,
        steps=args.steps,
        guidance=args.guidance,
        seed=args.seed,
        scheduler=args.scheduler,
        controlnet=args.controlnet,
        control_asset_id=args.control_asset_id,
        control_image=args.control_image,
        controlnet_strength=args.controlnet_strength,
        output=args.output,
        project_root=Path(args.project_root).resolve(),
    )


if __name__ == "__main__":
    main()
