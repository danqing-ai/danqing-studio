#!/usr/bin/env python3
"""
danqing-audio-edit — 音频编辑 CLI（cover / 同声翻唱）。

对应 REST API: POST /api/audios/edits → IAudioEngine.edit()

用法:
    danqing-audio-edit --model ace-step-xl-sft --operation cover \\
        --source-audio ref.wav --prompt "jazz piano cover" \\
        --source-fidelity 0.8 --output out.wav
"""
from __future__ import annotations

import argparse
import os
import sys
from pathlib import Path

_CLI_FILE = Path(__file__).resolve()
PROJECT_ROOT = _CLI_FILE.parent.parent
if sys.platform != "win32":
    _venv_root = PROJECT_ROOT / ".venv"
    _venv_py = _venv_root / "bin" / "python3"
    if _venv_py.is_file() and Path(sys.prefix).resolve() != _venv_root.resolve():
        os.execv(str(_venv_py), [str(_venv_py), str(_CLI_FILE), *sys.argv[1:]])
sys.path.insert(0, str(PROJECT_ROOT))

from backend.cli.audio_cli import edit


def main() -> None:
    parser = argparse.ArgumentParser(description="DanQing CLI: audio edit (cover)")
    parser.add_argument("--model", required=True, help="Model ID (e.g. ace-step-xl-sft)")
    parser.add_argument("--operation", default="cover", choices=["cover"])
    parser.add_argument("--source-asset-id", default="", help="Existing asset id")
    parser.add_argument("--source-audio", default="", help="Local wav/mp3 path (uploaded as asset)")
    parser.add_argument("--prompt", default="", help="Optional style/caption hint")
    parser.add_argument(
        "--source-fidelity",
        type=float,
        default=1.0,
        help="Reference strength 0.0–1.0 (higher = closer to source)",
    )
    parser.add_argument("--steps", type=int, default=None)
    parser.add_argument("--guidance", type=float, default=None)
    parser.add_argument("--seed", type=int, default=None)
    parser.add_argument("--n", type=int, default=1)
    parser.add_argument("--audio-format", default="wav")
    parser.add_argument("--output", required=True, help="Output audio path")
    parser.add_argument("--project-root", default=str(PROJECT_ROOT))
    args = parser.parse_args()

    print(
        f"[cli] model={args.model} operation={args.operation} "
        f"fidelity={args.source_fidelity}"
    )
    edit(
        model=args.model,
        operation=args.operation,
        source_asset_id=args.source_asset_id,
        source_audio=args.source_audio,
        prompt=args.prompt,
        source_fidelity=args.source_fidelity,
        steps=args.steps,
        guidance=args.guidance,
        seed=args.seed,
        n=args.n,
        audio_format=args.audio_format,
        output=args.output,
        project_root=Path(args.project_root).resolve(),
    )


if __name__ == "__main__":
    main()
