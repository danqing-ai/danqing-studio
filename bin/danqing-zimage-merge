#!/usr/bin/env python3
"""danqing-zimage-merge — weighted merge of Z-Image-Turbo DiT bundles (MLX)."""
from __future__ import annotations

import argparse
import os
import sys
from pathlib import Path

_CLI_FILE = Path(__file__).resolve()
PROJECT_ROOT = _CLI_FILE.parent.parent
if sys.platform != "win32":
    _venv_root = PROJECT_ROOT / ".venv"
    _venv_py = _venv_root / "bin" / "python3"
    if _venv_py.is_file() and Path(sys.prefix).resolve() != _venv_root.resolve():
        os.execv(str(_venv_py), [str(_venv_py), str(_CLI_FILE), *sys.argv[1:]])
sys.path.insert(0, str(PROJECT_ROOT))

from backend.cli.z_image_merge_cli import merge_z_image


def main() -> None:
    parser = argparse.ArgumentParser(description="DanQing CLI: Z-Image DiT weight merge")
    parser.add_argument("--model-a", required=True, help="First model id (e.g. z-image-turbo:fp16)")
    parser.add_argument("--model-b", required=True, help="Second model id")
    parser.add_argument("--model-c", default=None, help="Original base for add_difference merge")
    parser.add_argument(
        "--method",
        default="weighted_sum",
        choices=["weighted_sum", "add_difference"],
    )
    parser.add_argument("--alpha", type=float, default=0.5, help="Blend weight toward model B")
    parser.add_argument("--output-name", required=True, help="Output folder name under models/Image/")
    args = parser.parse_args()
    merge_z_image(
        model_a=args.model_a,
        model_b=args.model_b,
        model_c=args.model_c,
        method=args.method,
        alpha=args.alpha,
        output_name=args.output_name,
    )


if __name__ == "__main__":
    main()
