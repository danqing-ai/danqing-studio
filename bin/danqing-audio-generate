#!/usr/bin/env python3
"""
danqing-audio-generate — 文生音乐 CLI。

对应 REST API: POST /api/audios/generations → IAudioEngine.generate()

用法:
    danqing-audio-generate --model audio-stub --prompt "demo" --duration 30 --output out.mp3
    # 当前仓库无音频推理后端，任务会显式失败；此 CLI 仅用于对齐 API 契约。
"""
from __future__ import annotations

import argparse
import os
import sys
from pathlib import Path

_CLI_FILE = Path(__file__).resolve()
PROJECT_ROOT = _CLI_FILE.parent.parent
# Prefer repo venv (MLX) when the user runs ./bin/danqing-* without activating .venv
if sys.platform != "win32":
    _venv_root = PROJECT_ROOT / ".venv"
    _venv_py = _venv_root / "bin" / "python3"
    if _venv_py.is_file() and Path(sys.prefix).resolve() != _venv_root.resolve():
        os.execv(str(_venv_py), [str(_venv_py), str(_CLI_FILE), *sys.argv[1:]])
sys.path.insert(0, str(PROJECT_ROOT))

from backend.cli.audio_cli import generate


def main():
    parser = argparse.ArgumentParser(description="DanQing CLI: text-to-music generation")
    parser.add_argument("--model", required=True, help="Model ID (e.g. audio-stub)")
    parser.add_argument("--prompt", required=True)
    parser.add_argument("--negative-prompt", default="")
    parser.add_argument("--duration", type=int, default=None, help="Duration in seconds (10-600)")
    parser.add_argument("--instrumental", action="store_true")
    parser.add_argument("--lyrics", default="")
    parser.add_argument("--vocal-language", default="")
    parser.add_argument("--bpm", type=int, default=None)
    parser.add_argument("--key-scale", default="")
    parser.add_argument("--time-signature", default="")
    parser.add_argument("--steps", type=int, default=None)
    parser.add_argument("--guidance", type=float, default=None)
    parser.add_argument("--seed", type=int, default=None)
    parser.add_argument("--n", type=int, default=2)
    parser.add_argument("--audio-format", default="mp3")
    parser.add_argument("--output", required=True, help="Output audio path")
    parser.add_argument("--project-root", default=str(PROJECT_ROOT))
    args = parser.parse_args()

    print(f"[cli] model={args.model} prompt={args.prompt!r} duration={args.duration}")
    generate(
        model=args.model,
        prompt=args.prompt,
        negative_prompt=args.negative_prompt,
        duration=args.duration,
        instrumental=args.instrumental,
        lyrics=args.lyrics,
        vocal_language=args.vocal_language,
        bpm=args.bpm,
        key_scale=args.key_scale,
        time_signature=args.time_signature,
        steps=args.steps,
        guidance=args.guidance,
        seed=args.seed,
        n=args.n,
        audio_format=args.audio_format,
        output=args.output,
        project_root=Path(args.project_root).resolve(),
    )


if __name__ == "__main__":
    main()
