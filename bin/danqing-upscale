#!/usr/bin/env python3
"""
danqing-upscale — 图像放大 CLI。

对应 REST API: POST /api/images/upscales → IImageEngine.upscale()

用法:
    danqing-upscale --model seedvr2-7b --source-asset-id ast_xxx --output out.png
    danqing-upscale --model seedvr2-7b --source-image ./in.png --output out.png
"""
from __future__ import annotations

import argparse
import os
import sys
from pathlib import Path

_CLI_FILE = Path(__file__).resolve()
PROJECT_ROOT = _CLI_FILE.parent.parent
if sys.platform != "win32":
    _venv_root = PROJECT_ROOT / ".venv"
    _venv_py = _venv_root / "bin" / "python3"
    if _venv_py.is_file() and Path(sys.prefix).resolve() != _venv_root.resolve():
        os.execv(str(_venv_py), [str(_venv_py), str(_CLI_FILE), *sys.argv[1:]])
sys.path.insert(0, str(PROJECT_ROOT))

from backend.cli.image_cli import upscale


def main():
    parser = argparse.ArgumentParser(description="DanQing CLI: image upscaling")
    parser.add_argument("--model", required=True)
    src = parser.add_mutually_exclusive_group(required=True)
    src.add_argument("--source-asset-id", default="")
    src.add_argument("--source-image", default="")
    parser.add_argument("--scale-factor", type=float, default=2.0)
    parser.add_argument("--seed", type=int, default=None, help="RNG seed (SeedVR2 upscale)")
    parser.add_argument(
        "--denoise",
        type=float,
        default=None,
        help="Softness 0–1 for SeedVR2 (default: API default from request schema)",
    )
    parser.add_argument("--output", required=True)
    parser.add_argument("--project-root", default=str(PROJECT_ROOT))
    args = parser.parse_args()

    print(f"[cli] model={args.model} scale={args.scale_factor}")
    upscale(
        model=args.model,
        source_asset_id=args.source_asset_id,
        source_image=args.source_image,
        scale_factor=args.scale_factor,
        seed=args.seed,
        denoise=args.denoise,
        output=args.output,
        project_root=Path(args.project_root).resolve(),
    )


if __name__ == "__main__":
    main()
