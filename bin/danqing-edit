#!/usr/bin/env python3
"""
danqing-edit — 图像编辑 CLI。

对应 REST API: POST /api/images/edits → IImageEngine.edit()

用法:
    danqing-edit --model z-image --operation rewrite --source-asset-id ast_xxx \
                 --prompt "add snow" --output out.png
"""
from __future__ import annotations

import argparse
import sys
from pathlib import Path

PROJECT_ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(PROJECT_ROOT))

from backend.cli.image_cli import edit


def main():
    parser = argparse.ArgumentParser(description="DanQing CLI: image editing")
    parser.add_argument("--model", required=True)
    parser.add_argument("--operation", required=True, choices=["rewrite", "retouch", "extend"])
    parser.add_argument("--source-asset-id", required=True)
    parser.add_argument("--prompt", required=True)
    parser.add_argument("--source-fidelity", type=float, default=0.6)
    parser.add_argument("--negative-prompt", default="")
    parser.add_argument("--steps", type=int, default=None)
    parser.add_argument("--seed", type=int, default=None)
    parser.add_argument("--output", required=True)
    parser.add_argument("--project-root", default=str(PROJECT_ROOT))
    args = parser.parse_args()

    print(f"[cli] model={args.model} op={args.operation} prompt={args.prompt!r}")
    edit(
        model=args.model,
        operation=args.operation,
        source_asset_id=args.source_asset_id,
        prompt=args.prompt,
        source_fidelity=args.source_fidelity,
        negative_prompt=args.negative_prompt,
        steps=args.steps,
        seed=args.seed,
        output=args.output,
        project_root=Path(args.project_root).resolve(),
    )


if __name__ == "__main__":
    main()
