#!/usr/bin/env python3
"""
danqing-edit — 图像编辑 CLI。

对应 REST API: POST /api/images/edits → IImageEngine.edit()

用法:
    # img2img rewrite
    danqing-edit --model flux1-dev --operation rewrite --source-image in.png \
                 --prompt "add snow" --output out.png

    # FLUX Fill inpainting (retouch)
    danqing-edit --model flux-fill-controlnet --operation retouch \
                 --source-image photo.png --mask-image mask.png \
                 --prompt "a red backpack" --guidance 30 --output out.png

    # FLUX Fill outpainting (extend)
    danqing-edit --model flux-fill-controlnet --operation extend \
                 --source-image photo.png --extend-directions right \
                 --extend-pixels 256 --prompt "continue the landscape" --output out.png
"""
from __future__ import annotations

import argparse
import os
import sys
from pathlib import Path

_CLI_FILE = Path(__file__).resolve()
PROJECT_ROOT = _CLI_FILE.parent.parent
if sys.platform != "win32":
    _venv_root = PROJECT_ROOT / ".venv"
    _venv_py = _venv_root / "bin" / "python3"
    if _venv_py.is_file() and Path(sys.prefix).resolve() != _venv_root.resolve():
        os.execv(str(_venv_py), [str(_venv_py), str(_CLI_FILE), *sys.argv[1:]])
sys.path.insert(0, str(PROJECT_ROOT))

from backend.cli.image_cli import edit


def _parse_extend_directions(raw: str) -> list[str]:
    if not raw:
        return []
    return [p.strip().lower() for p in raw.split(",") if p.strip()]


def main():
    parser = argparse.ArgumentParser(description="DanQing CLI: image editing")
    parser.add_argument("--model", required=True)
    parser.add_argument("--operation", required=True, choices=["rewrite", "retouch", "extend"])
    parser.add_argument("--source-asset-id", default="")
    parser.add_argument("--source-image", default="", help="Local image file path (alternative to --source-asset-id)")
    parser.add_argument("--mask-asset-id", default="", help="Mask asset id (retouch; white = repaint)")
    parser.add_argument("--mask-image", default="", help="Local mask PNG path (uploaded as asset)")
    parser.add_argument(
        "--extend-directions",
        default="",
        help="Outpaint directions, comma-separated: top,bottom,left,right (extend only)",
    )
    parser.add_argument("--extend-pixels", type=int, default=256, help="Outpaint padding per side (64–2048)")
    parser.add_argument("--prompt", required=True)
    parser.add_argument("--source-fidelity", type=float, default=0.6, help="rewrite img2img strength proxy")
    parser.add_argument("--negative-prompt", default="")
    parser.add_argument(
        "--guidance",
        type=float,
        default=None,
        help="CFG scale (Fill retouch/extend default ~30 from registry if omitted)",
    )
    parser.add_argument("--steps", type=int, default=None)
    parser.add_argument("--seed", type=int, default=None)
    parser.add_argument(
        "--scheduler",
        default=None,
        help="Override scheduler id (registry default if omitted)",
    )
    parser.add_argument("--output", required=True)
    parser.add_argument("--project-root", default=str(PROJECT_ROOT))
    args = parser.parse_args()

    print(f"[cli] model={args.model} op={args.operation} prompt={args.prompt!r}")
    edit(
        model=args.model,
        operation=args.operation,
        prompt=args.prompt,
        source_asset_id=args.source_asset_id,
        source_image=args.source_image,
        mask_asset_id=args.mask_asset_id,
        mask_image=args.mask_image,
        extend_directions=_parse_extend_directions(args.extend_directions),
        extend_pixels=args.extend_pixels,
        source_fidelity=args.source_fidelity,
        negative_prompt=args.negative_prompt,
        guidance=args.guidance,
        steps=args.steps,
        seed=args.seed,
        scheduler=args.scheduler,
        output=args.output,
        project_root=Path(args.project_root).resolve(),
    )


if __name__ == "__main__":
    main()
