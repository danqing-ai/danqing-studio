#!/usr/bin/env python3
"""
danqing-video-generate — 文生视频 CLI。

对应 REST API: POST /api/videos/generations → IVideoEngine.generate()

用法:
    danqing-video-generate --model wan-2.2-t2v-5b --prompt "a sunset" --output out.mp4
"""
from __future__ import annotations

import argparse
import os
import sys
from pathlib import Path

_CLI_FILE = Path(__file__).resolve()
PROJECT_ROOT = _CLI_FILE.parent.parent
if sys.platform != "win32":
    _venv_root = PROJECT_ROOT / ".venv"
    _venv_py = _venv_root / "bin" / "python3"
    if _venv_py.is_file() and Path(sys.prefix).resolve() != _venv_root.resolve():
        os.execv(str(_venv_py), [str(_venv_py), str(_CLI_FILE), *sys.argv[1:]])
sys.path.insert(0, str(PROJECT_ROOT))

from backend.cli.video_cli import generate


def main():
    parser = argparse.ArgumentParser(description="DanQing CLI: text-to-video generation")
    parser.add_argument("--model", required=True)
    parser.add_argument("--prompt", required=True)
    parser.add_argument("--negative-prompt", default="")
    parser.add_argument("--size", default="1024x1024")
    parser.add_argument("--num-frames", type=int, default=None, help="Pixel frames (registry / model constraints apply)")
    parser.add_argument("--fps", type=int, default=None, help="Output video frame rate")
    parser.add_argument("--steps", type=int, default=None)
    parser.add_argument("--guidance", type=float, default=None)
    parser.add_argument("--shift", type=float, default=None, help="Flow schedule shift (Wan default 5)")
    parser.add_argument("--seed", type=int, default=None)
    parser.add_argument(
        "--teacache-mode",
        default=None,
        choices=["none", "auto", "fast", "quality"],
        help="TeaCache step cache (wan/hunyuan; registry default if omitted)",
    )
    parser.add_argument("--output", required=True)
    parser.add_argument("--project-root", default=str(PROJECT_ROOT))
    args = parser.parse_args()

    print(f"[cli] model={args.model} prompt={args.prompt!r}")
    generate(
        model=args.model,
        prompt=args.prompt,
        negative_prompt=args.negative_prompt,
        size=args.size,
        num_frames=args.num_frames,
        fps=args.fps,
        steps=args.steps,
        guidance=args.guidance,
        shift=args.shift,
        seed=args.seed,
        teacache_mode=args.teacache_mode,
        output=args.output,
        project_root=Path(args.project_root).resolve(),
    )


if __name__ == "__main__":
    main()
