#!/usr/bin/env python3
"""danqing-lora-train — DreamBooth LoRA training CLI."""
from __future__ import annotations

import argparse
import os
import sys
from pathlib import Path

_CLI_FILE = Path(__file__).resolve()
PROJECT_ROOT = _CLI_FILE.parent.parent
if sys.platform != "win32":
    _venv_root = PROJECT_ROOT / ".venv"
    _venv_py = _venv_root / "bin" / "python3"
    if _venv_py.is_file() and Path(sys.prefix).resolve() != _venv_root.resolve():
        os.execv(str(_venv_py), [str(_venv_py), str(_CLI_FILE), *sys.argv[1:]])
sys.path.insert(0, str(PROJECT_ROOT))

from backend.cli.lora_train_cli import train


def main():
    parser = argparse.ArgumentParser(description="DanQing CLI: LoRA DreamBooth training")
    parser.add_argument("--config", default=None, help="JSON/YAML training config (overridden by CLI flags)")
    parser.add_argument("--base-model", default="flux1-dev", help="Base model id")
    parser.add_argument("--dataset", required=True, dest="dataset_id", help="Dataset id (ds_*)")
    parser.add_argument("--progress-prompt", required=True, help="Prompt for training previews")
    parser.add_argument(
        "--preset",
        default="standard",
        choices=["quick", "standard", "quality", "custom"],
    )
    parser.add_argument("--output-name", default="", help="Output LoRA folder name")
    parser.add_argument("--iterations", type=int, default=None)
    parser.add_argument("--lora-rank", type=int, default=None)
    parser.add_argument("--lora-blocks", type=int, default=None)
    parser.add_argument("--learning-rate", type=float, default=None)
    parser.add_argument("--qlora-bits", type=int, choices=[4, 8], default=None)
    parser.add_argument("--grad-checkpoint", action="store_true", default=None)
    parser.add_argument("--no-grad-checkpoint", action="store_true", help="Disable gradient checkpointing")
    parser.add_argument("--compile-step", action="store_true", default=None)
    parser.add_argument("--train-type", choices=["lora", "dora"], default=None)
    parser.add_argument("--min-snr-gamma", type=float, default=None)
    parser.add_argument("--class-prompt", default=None)
    parser.add_argument("--prior-loss-weight", type=float, default=None)
    parser.add_argument("--early-stop-patience", type=int, default=None)
    parser.add_argument("--fuse-adapters", action="store_true", default=None)
    parser.add_argument("--resume-from", default=None)
    parser.add_argument("--optimizer", choices=["adam", "adamw"], default=None)
    parser.add_argument("--val-split", type=float, default=None)
    parser.add_argument("--val-every", type=int, default=None)
    args = parser.parse_args()

    overrides: dict = {
        "base_model": args.base_model,
        "dataset_id": args.dataset_id,
        "progress_prompt": args.progress_prompt,
        "preset": args.preset,
        "output_name": args.output_name,
        "iterations": args.iterations,
        "lora_rank": args.lora_rank,
        "lora_blocks": args.lora_blocks,
        "learning_rate": args.learning_rate,
        "qlora_bits": args.qlora_bits,
        "compile_step": args.compile_step,
        "train_type": args.train_type,
        "min_snr_gamma": args.min_snr_gamma,
        "class_prompt": args.class_prompt,
        "prior_loss_weight": args.prior_loss_weight,
        "early_stop_patience": args.early_stop_patience,
        "fuse_adapters": args.fuse_adapters,
        "resume_from": args.resume_from,
        "optimizer": args.optimizer,
        "val_split": args.val_split,
        "val_every": args.val_every,
    }
    if args.grad_checkpoint:
        overrides["grad_checkpoint"] = True
    if args.no_grad_checkpoint:
        overrides["grad_checkpoint"] = False

    if args.config:
        from backend.engine.training.lora_train_config import merge_config_into_request_dict

        overrides = merge_config_into_request_dict(
            {k: v for k, v in overrides.items() if v is not None},
            args.config,
        )
    else:
        overrides = {k: v for k, v in overrides.items() if v is not None}

    train(**overrides)


if __name__ == "__main__":
    main()
