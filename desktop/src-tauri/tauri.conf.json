{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DanQing Studio",
  "version": "0.1.0",
  "identifier": "com.danqing.studio.desktop",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://127.0.0.1:7860",
    "frontendDist": "../loader"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DanQing Studio",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "DeveloperTool",
    "shortDescription": "DanQing Studio desktop",
    "longDescription": "Native shell for the DanQing Studio FastAPI server (REST).",
    "icon": ["icons/icon.png"],
    "resources": ["danqing-api"]
  }
}
